@rendermode InteractiveServer
@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider

@* Provedores globais obrigatórios do MudBlazor *@
<MudThemeProvider Theme="_currentTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="background-color: #F5F3EF; color: #2C3531;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@(() => DrawerToggle())" />
        <img src="/images/logo2.svg" alt="SAAF Logo" style="height: 36px; margin-right: 12px; margin-left: 12px;" />
        <MudText Typo="Typo.h5" Style="font-family: 'Playfair Display', serif; font-weight: 700; color: #2C3531;">SAAF</MudText>
        <MudSpacer />

        <AuthorizeView Context="authContext">
            <Authorized>
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <div class="d-flex align-center gap-2" style="cursor:pointer; padding: 4px 8px; border-radius: 8px; transition: background 0.2s;"
                             @onclick="@context.ToggleAsync"
                             onmouseover="this.style.background='rgba(44, 53, 49, 0.05)'"
                             onmouseout="this.style.background='transparent'">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-size:0.8rem;">
                                @GetIniciais(authContext.User.Identity?.Name)
                            </MudAvatar>
                            <div class="d-none d-sm-flex flex-column" style="line-height:1.2;">
                                <MudText Typo="Typo.body2" Style="color:#2C3531; font-weight:600;">
                                    @authContext.User.Identity?.Name
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#707070; font-size:0.68rem;">
                                    @GetRoleLabel(authContext.User)
                                </MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Style="color:#2C3531;" Size="Size.Small" />
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Lock" IconColor="Color.Primary" OnClick="@AbrirDialogAlterarSenha">
                            Alterar Senha
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error"
                                     OnClick="@RealizarLogout">
                            <MudText Color="Color.Error">Sair</MudText>
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
        <form id="logoutForm" action="/api/auth/logout" method="post" style="display:none;">
            <AntiforgeryToken />
        </form>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Style="background-color: #FDFCFB;">
        <div class="pa-4 d-flex justify-center align-center flex-column" style="background-color: #F5F3EF; border-bottom: 1px solid rgba(180, 172, 161, 0.2);">
            <img src="/images/logo1.svg" alt="SAAF Logo" style="height: 60px; margin-bottom: 8px;" />
            <MudText Typo="Typo.h6" Style="font-family: 'Playfair Display', serif; font-weight: 600; color: #2C3531;">Menu Principal</MudText>
        </div>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#8FA88C", // Verde Pastel
            Secondary = "#B4ACA1", // Greige médio
            Tertiary = "#2C3531", // Texto escuro / verde bem escuro
            Background = "#FDFCFB",
            AppbarBackground = "#F5F3EF",
            DrawerBackground = "#FDFCFB",
            Surface = "#ffffff",
            TextPrimary = "#3A3A3A",
            TextSecondary = "#707070",
            ActionDefault = "#B4ACA1",
            ActionDisabled = "rgba(180, 172, 161, 0.5)",
            TextDisabled = "rgba(58, 58, 58, 0.4)"
        }
    };

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    // SEC-05: Logout via POST — submete um form oculto via JS para incluir antiforgery token
    private async Task RealizarLogout()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('logoutForm').submit()");
    }

    private async Task AbrirDialogAlterarSenha()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
            // The dialog will handle the user internally based on current auth state
            await DialogService.ShowAsync<Sakrus.Components.Pages.AlterarSenhaDialog>("Alterar Minha Senha", options);
        }
    }

    private string GetIniciais(string? nomeCompleto)
    {
        if (string.IsNullOrWhiteSpace(nomeCompleto)) return "?";
        var partes = nomeCompleto.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return partes.Length >= 2
            ? $"{partes[0][0]}{partes[^1][0]}".ToUpper()
            : nomeCompleto[..Math.Min(2, nomeCompleto.Length)].ToUpper();
    }

    private string GetRoleLabel(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.IsInRole("Admin")) return "Administrador";
        if (user.IsInRole("Operador")) return "Operador";
        return "Visualizador";
    }
}
