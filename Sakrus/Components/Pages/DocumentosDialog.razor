@using Sakrus.Core.Entities
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IWebHostEnvironment WebHostEnvironment

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Documentos Anexos</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <div class="d-flex justify-center align-center pa-6">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                @FalecidoNome
            </MudText>

            @* ───── Seção de upload ───── *@
            <MudPaper Outlined="true" Class="pa-3 mb-4">
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" Class="mr-1" />
                    Anexar novos documentos (PDF)
                </MudText>

                <InputFile id="fileInputDialog" OnChange="OnFileSelected" multiple accept=".pdf" style="display:none" />

                <div class="d-flex align-center gap-2 flex-wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.AttachFile"
                               Size="Size.Small"
                               OnClick="TriggerFileInput"
                               Disabled="@isSalvando">
                        Selecionar PDF(s)
                    </MudButton>

                    @if (arquivosParaAnexar.Any())
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   Size="Size.Small"
                                   OnClick="SalvarAnexos"
                                   Disabled="@isSalvando">
                            @if (isSalvando)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Salvando...</span>
                            }
                            else
                            {
                                <span>Salvar @arquivosParaAnexar.Count arquivo(s)</span>
                            }
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="LimparSelecao"
                                   Disabled="@isSalvando">
                            Limpar
                        </MudButton>
                    }
                </div>

                @if (arquivosParaAnexar.Any())
                {
                    <MudList T="string" Dense="true" Class="mt-2">
                        @foreach (var arq in arquivosParaAnexar)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.PictureAsPdf" IconColor="Color.Error">
                                <div class="d-flex align-center justify-space-between" style="width:100%">
                                    <MudText Typo="Typo.body2">
                                        @arq.Name
                                        <MudText Inline="true" Typo="Typo.caption" Color="Color.Secondary">(@FormatBytes(arq.Size))</MudText>
                                    </MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => RemoverArquivo(arq))" />
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }

                @if (!string.IsNullOrEmpty(erroUpload))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@erroUpload</MudAlert>
                }
            </MudPaper>

            @* ───── Lista de documentos existentes ───── *@
            @if (documentos.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
                    Nenhum documento foi anexado a este falecido ainda.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@documentos" Hover="true" Striped="true" Elevation="0" Dense="true">
                    <HeaderContent>
                        <MudTh>
                            <MudTableSortLabel SortBy="new Func<DocumentoAnexo, object>(x => x.NomeArquivo)">
                                Nome do Arquivo
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh>Tamanho</MudTh>
                        <MudTh>
                            <MudTableSortLabel SortBy="new Func<DocumentoAnexo, object>(x => x.DataAnexo)" InitialDirection="SortDirection.Descending">
                                Data de Anexo
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh Style="text-align:center">Download</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Nome do Arquivo">
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small" />
                                <MudText Typo="Typo.body2">@context.NomeArquivo</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Tamanho">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatBytes(context.TamanhoBytes)</MudText>
                        </MudTd>
                        <MudTd DataLabel="Data de Anexo">
                            <MudText Typo="Typo.caption">@context.DataAnexo.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Download" Style="text-align:center">
                            <MudIconButton Icon="@Icons.Material.Filled.Download"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@baixandoId.Contains(context.Id)"
                                           OnClick="@(() => BaixarDocumento(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3 d-block text-right">
                    @documentos.Count documento(s) encontrado(s)
                </MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Fechar" Variant="Variant.Text">Fechar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private ApplicationDbContext DbContext = default!;

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int FalecidoId { get; set; }
    [Parameter] public int AtendimentoId { get; set; }
    [Parameter] public string FalecidoNome { get; set; } = string.Empty;

    // ── Estado da lista de documentos ──
    private List<DocumentoAnexo> documentos = new();
    private bool isLoading = true;
    private HashSet<int> baixandoId = new();

    // ── Estado do upload ──
    // Mesmo padrão do NovoAtendimento: leitura eager para evitar IBrowserFile stale.
    private sealed record ArquivoBuffer(string Name, long Size, byte[] Bytes);
    private List<ArquivoBuffer> arquivosParaAnexar = new();
    private string erroUpload = string.Empty;
    private bool isSalvando = false;
    private const long MaxFileSizeBytes = 10 * 1024 * 1024; // 10 MB

    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();
        await CarregarDocumentosAsync();
    }

    private async Task CarregarDocumentosAsync()
    {
        isLoading = true;
        documentos = await DbContext.DocumentosAnexos
            .Where(d => d.FalecidoId == FalecidoId)
            .OrderByDescending(d => d.DataAnexo)
            .ToListAsync();
        isLoading = false;
    }

    // ── Upload ──────────────────────────────────────────────────────────────

    private async Task TriggerFileInput()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('fileInputDialog').click()");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        erroUpload = string.Empty;
        var rejeitados = new List<string>();

        foreach (var file in e.GetMultipleFiles(20))
        {
            if (!file.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase)
                && !file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
            {
                rejeitados.Add($"{file.Name} (tipo inválido — apenas PDF)");
                continue;
            }

            if (file.Size > MaxFileSizeBytes)
            {
                rejeitados.Add($"{file.Name} (excede 10 MB)");
                continue;
            }

            if (arquivosParaAnexar.Any(a => a.Name == file.Name))
                continue;

            // Leitura eager — IBrowserFile expira após re-render
            try
            {
                using var ms = new MemoryStream();
                await using var stream = file.OpenReadStream(MaxFileSizeBytes);
                await stream.CopyToAsync(ms);
                arquivosParaAnexar.Add(new ArquivoBuffer(file.Name, file.Size, ms.ToArray()));
            }
            catch (Exception ex)
            {
                rejeitados.Add($"{file.Name} (erro ao ler: {ex.Message})");
            }
        }

        if (rejeitados.Any())
            erroUpload = $"Arquivo(s) rejeitado(s): {string.Join("; ", rejeitados)}";
    }

    private void RemoverArquivo(ArquivoBuffer arq)
    {
        arquivosParaAnexar.Remove(arq);
        erroUpload = string.Empty;
    }

    private void LimparSelecao()
    {
        arquivosParaAnexar.Clear();
        erroUpload = string.Empty;
    }

    private async Task SalvarAnexos()
    {
        if (!arquivosParaAnexar.Any()) return;

        isSalvando = true;
        StateHasChanged();

        try
        {
            var pastaBase = Path.Combine(
                WebHostEnvironment.WebRootPath,
                "uploads", "atendimentos", FalecidoId.ToString());

            Directory.CreateDirectory(pastaBase);

            foreach (var arquivo in arquivosParaAnexar)
            {
                var nomeUnico = $"{Guid.NewGuid():N}_{Path.GetFileName(arquivo.Name)}";
                var caminhoFisico = Path.Combine(pastaBase, nomeUnico);

                await File.WriteAllBytesAsync(caminhoFisico, arquivo.Bytes);

                var doc = new DocumentoAnexo
                {
                    AtendimentoId = AtendimentoId,
                    FalecidoId = FalecidoId,
                    NomeArquivo = arquivo.Name,
                    // Sempre '/' para compatibilidade Windows ↔ Linux/Docker
                    CaminhoArquivo = $"uploads/atendimentos/{FalecidoId}/{nomeUnico}",
                    TamanhoBytes = arquivo.Bytes.LongLength,
                    DataAnexo = DateTime.UtcNow
                };

                DbContext.DocumentosAnexos.Add(doc);
            }

            await DbContext.SaveChangesAsync();

            var quantidade = arquivosParaAnexar.Count;
            arquivosParaAnexar.Clear();
            erroUpload = string.Empty;

            // Recarrega a lista para exibir os documentos recém-adicionados
            DbContext.ChangeTracker.Clear();
            await CarregarDocumentosAsync();

            Snackbar.Add($"{quantidade} documento(s) anexado(s) com sucesso!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao salvar documentos: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSalvando = false;
            StateHasChanged();
        }
    }

    // ── Download ─────────────────────────────────────────────────────────────

    private async Task BaixarDocumento(DocumentoAnexo doc)
    {
        if (baixandoId.Contains(doc.Id)) return;
        baixandoId.Add(doc.Id);
        StateHasChanged();

        try
        {
            var caminhoRelativo = doc.CaminhoArquivo
                .Replace('\\', Path.DirectorySeparatorChar)
                .Replace('/', Path.DirectorySeparatorChar);

            var caminhoFisico = Path.Combine(WebHostEnvironment.WebRootPath, caminhoRelativo);

            if (!File.Exists(caminhoFisico))
            {
                Snackbar.Add(
                    $"Arquivo não encontrado no servidor: {doc.NomeArquivo}. " +
                    $"O arquivo pode ter sido perdido após reinicialização do servidor.",
                    Severity.Error);
                return;
            }

            var bytes = await File.ReadAllBytesAsync(caminhoFisico);
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", doc.NomeArquivo, Convert.ToBase64String(bytes));
            Snackbar.Add($"Download iniciado: {doc.NomeArquivo}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao baixar o arquivo: {ex.Message}", Severity.Error);
        }
        finally
        {
            baixandoId.Remove(doc.Id);
            StateHasChanged();
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private void Fechar() => MudDialog.Cancel();
}
