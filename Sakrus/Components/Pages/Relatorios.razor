@page "/relatorios"
@attribute [Authorize]
@using Sakrus.Core.Entities
@using Sakrus.Services
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject RelatorioService RelatorioService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Relatórios - SAAF</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h4">Relatórios e Extratos</MudText>
</div>

<MudPaper Class="pa-4 mb-6 d-flex flex-wrap align-center gap-4" Elevation="2">
    <MudText Typo="Typo.subtitle1" Class="mr-2">Filtro de Período:</MudText>
    
    <div style="max-width: 300px;">
        <MudDateRangePicker @bind-DateRange="dateRange"
                            Label="Período"
                            Editable="true"
                            Color="Color.Primary"
                            Rounded="true"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense" />
    </div>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SetUltimos30Dias" Size="Size.Small">
        Últimos 30 Dias
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="SetEsteAno" Size="Size.Small">
        Este Ano
    </MudButton>
</MudPaper>

<MudGrid>
    @* Card 1: Relatório de Atendimentos *@
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="h-100 d-flex flex-column">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                <MudText Typo="Typo.h6">Atendimentos</MudText>
                <MudText Typo="Typo.body2">Listagem de óbitos e atendimentos registrados</MudText>
            </MudCardContent>
            <MudCardActions Class="mt-auto">
                <MudButton StartIcon="@Icons.Custom.FileFormats.FilePdf" Color="Color.Error" OnClick='() => Gerar("Atendimentos", "PDF")'>
                    PDF
                </MudButton>
                <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Color="Color.Info" OnClick='() => Gerar("Atendimentos", "TXT")'>
                    TXT
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* Card 2: Relatório de Jazigos *@
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="h-100 d-flex flex-column">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.GridOn" Size="Size.Large" Color="Color.Warning" Class="mb-3" />
                <MudText Typo="Typo.h6">Lotação de Jazigos</MudText>
                <MudText Typo="Typo.body2">Status de ocupação do cemitério (Não usa filtro de data)</MudText>
            </MudCardContent>
            <MudCardActions Class="mt-auto">
                <MudButton StartIcon="@Icons.Custom.FileFormats.FilePdf" Color="Color.Error" OnClick='() => Gerar("Jazigos", "PDF")'>
                    PDF
                </MudButton>
                <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Color="Color.Info" OnClick='() => Gerar("Jazigos", "TXT")'>
                    TXT
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* Card 3: Relatório Financeiro *@
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="h-100 d-flex flex-column">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                <MudText Typo="Typo.h6">Faturamento Mensal</MudText>
                <MudText Typo="Typo.body2">Ordens de Serviço geradas</MudText>
            </MudCardContent>
            <MudCardActions Class="mt-auto">
                <MudButton StartIcon="@Icons.Custom.FileFormats.FilePdf" Color="Color.Error" OnClick='() => Gerar("Financeiro", "PDF")'>
                    PDF
                </MudButton>
                <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Color="Color.Info" OnClick='() => Gerar("Financeiro", "TXT")'>
                    TXT
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* Card 4: Relatório de Exumações *@
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="h-100 d-flex flex-column">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                <MudText Typo="Typo.h6">Exumações</MudText>
                <MudText Typo="Typo.body2">Histórico de liberação de jazigos</MudText>
            </MudCardContent>
            <MudCardActions Class="mt-auto">
                <MudButton StartIcon="@Icons.Custom.FileFormats.FilePdf" Color="Color.Error" OnClick='() => Gerar("Exumacoes", "PDF")'>
                    PDF
                </MudButton>
                <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Color="Color.Info" OnClick='() => Gerar("Exumacoes", "TXT")'>
                    TXT
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* Card 5: Estatísticas de Óbitos *@
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="h-100 d-flex flex-column">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large" Color="Color.Tertiary" Class="mb-3" />
                <MudText Typo="Typo.h6">Estatísticas de Óbito</MudText>
                <MudText Typo="Typo.body2">Agrupamento por Causas de morte</MudText>
            </MudCardContent>
            <MudCardActions Class="mt-auto">
                <MudButton StartIcon="@Icons.Custom.FileFormats.FilePdf" Color="Color.Error" OnClick='() => Gerar("Estatisticas", "PDF")'>
                    PDF
                </MudButton>
                <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Color="Color.Info" OnClick='() => Gerar("Estatisticas", "TXT")'>
                    TXT
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

<MudOverlay Visible="isGenerating" DarkBackground="true" ZIndex="9999">
    <div class="d-flex flex-column align-center justify-center">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4" Color="Color.Primary">Gerando arquivo, aguarde...</MudText>
    </div>
</MudOverlay>

@code {
    private ApplicationDbContext DbContext = default!;
    private DateRange dateRange = new DateRange(DateTime.Today.AddDays(-30), DateTime.Today);
    private bool isGenerating = false;

    protected override void OnInitialized()
    {
        DbContext = DbFactory.CreateDbContext();
    }

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    private void SetUltimos30Dias()
    {
        dateRange = new DateRange(DateTime.Today.AddDays(-30), DateTime.Today);
    }

    private void SetEsteAno()
    {
        dateRange = new DateRange(new DateTime(DateTime.Today.Year, 1, 1), DateTime.Today);
    }

    private string GetPeriodoString()
    {
        if (dateRange?.Start != null && dateRange?.End != null)
        {
            return $"{dateRange.Start.Value:dd/MM/yyyy} a {dateRange.End.Value:dd/MM/yyyy}";
        }
        return "Todo o período";
    }

    private async Task Gerar(string tipoRelatorio, string formato)
    {
        if (isGenerating) return;

        try
        {
            isGenerating = true;
            StateHasChanged();
            await Task.Delay(50); // Dá tempo pra UI renderizar o spinner

            var inicioLocal = dateRange.Start;
            // Para incluir o dia todo até o último segundo
            var fimLocal = dateRange.End?.AddDays(1).AddSeconds(-1); 

            // Npgsql requer UTC para colunas timestamptz
            DateTime? inicio = inicioLocal.HasValue ? DateTime.SpecifyKind(inicioLocal.Value, DateTimeKind.Utc) : null;
            DateTime? fim = fimLocal.HasValue ? DateTime.SpecifyKind(fimLocal.Value, DateTimeKind.Utc) : null; 
            var periodoStr = GetPeriodoString();
            byte[] fileBytes = [];
            string fileName = $"{tipoRelatorio}_{DateTime.Now:yyyyMMddHHmmss}.{formato.ToLower()}";
            string contentType = formato == "PDF" ? "application/pdf" : "text/plain";

            switch (tipoRelatorio)
            {
                case "Atendimentos":
                    var queryAtend = DbContext.Atendimentos
                        .Include(a => a.Responsavel)
                        .Include(a => a.Falecido)
                        .AsNoTracking()
                        .AsQueryable();

                    if (inicio.HasValue) queryAtend = queryAtend.Where(a => a.DataSepultamento >= inicio.Value);
                    if (fim.HasValue) queryAtend = queryAtend.Where(a => a.DataSepultamento <= fim.Value);
                    
                    var atendimentos = await queryAtend.OrderByDescending(a => a.DataSepultamento).ToListAsync();
                    
                    if (formato == "PDF") fileBytes = RelatorioService.GerarPdfAtendimentos(atendimentos, periodoStr);
                    else fileBytes = RelatorioService.GerarTxtAtendimentos(atendimentos, periodoStr);
                    break;

                case "Jazigos":
                    // Lotação é pontual (não usa data)
                    var jazigos = await DbContext.Jazigos.AsNoTracking().Include(j => j.ModeloJazigo).ToListAsync();
                    if (formato == "PDF") fileBytes = RelatorioService.GerarPdfJazigos(jazigos);
                    else fileBytes = RelatorioService.GerarTxtJazigos(jazigos);
                    break;

                case "Financeiro":
                    var queryFin = DbContext.Atendimentos
                        .Include(a => a.ItensFaturados)
                        .Include(a => a.Responsavel)
                        .AsNoTracking()
                        .Where(a => !string.IsNullOrEmpty(a.NumeroOsAuxilio));

                    if (inicio.HasValue) queryFin = queryFin.Where(a => a.DataSepultamento >= inicio.Value);
                    if (fim.HasValue) queryFin = queryFin.Where(a => a.DataSepultamento <= fim.Value);
                    
                    var financeiro = await queryFin.OrderByDescending(a => a.DataSepultamento).ToListAsync();
                    
                    if (formato == "PDF") fileBytes = RelatorioService.GerarPdfFinanceiro(financeiro, periodoStr);
                    else fileBytes = RelatorioService.GerarTxtFinanceiro(financeiro, periodoStr);
                    break;

                case "Exumacoes":
                    var queryExum = DbContext.ExumacoesRegistros
                        .Include(e => e.Falecido)
                        .AsNoTracking()
                        .AsQueryable();

                    if (inicio.HasValue) queryExum = queryExum.Where(e => e.DataExecucao >= inicio.Value);
                    if (fim.HasValue) queryExum = queryExum.Where(e => e.DataExecucao <= fim.Value);
                    
                    var exumacoes = await queryExum.OrderByDescending(e => e.DataExecucao).ToListAsync();
                    
                    if (formato == "PDF") fileBytes = RelatorioService.GerarPdfExumacoes(exumacoes, periodoStr);
                    else fileBytes = RelatorioService.GerarTxtExumacoes(exumacoes, periodoStr);
                    break;

                case "Estatisticas":
                    // Para evitar o bug do Enum SQL translation
                    var queryEst = DbContext.Falecidos.AsNoTracking().AsQueryable();
                    if (inicio.HasValue) queryEst = queryEst.Where(f => f.DataFalecimento >= inicio.Value);
                    if (fim.HasValue) queryEst = queryEst.Where(f => f.DataFalecimento <= fim.Value);

                    var resultEst = await queryEst
                        .GroupBy(f => f.CausaMorte)
                        .Select(g => new { Causa = g.Key, Quantidade = g.Count() })
                        .ToListAsync();
                        
                    var causas = resultEst.ToDictionary(x => x.Causa.ToString(), x => x.Quantidade);
                    
                    if (formato == "PDF") fileBytes = RelatorioService.GerarPdfEstatisticas(causas, periodoStr);
                    else fileBytes = RelatorioService.GerarTxtEstatisticas(causas, periodoStr);
                    break;
            }

            if (fileBytes.Length > 0)
            {
                var base64 = Convert.ToBase64String(fileBytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64, contentType);
                Snackbar.Add("Relatório gerado com sucesso!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Nenhum dado encontrado para o relatório.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao gerar {formato}: {ex.Message}", Severity.Error);
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }
}
