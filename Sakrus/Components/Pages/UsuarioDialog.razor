@using MudBlazor
@using Sakrus.Core.Entities
@using Sakrus.Services
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudTextField 
                @bind-Value="_usuario.Nome" 
                Label="Nome Completo" 
                Required="true"
                RequiredError="Nome obrigatório"
                Class="mb-4" />

            <MudTextField 
                @bind-Value="_usuario.Email" 
                Label="E-mail" 
                Required="true"
                RequiredError="E-mail obrigatório"
                InputType="InputType.Email"
                Class="mb-4" />

            @if (_isNovo)
            {
                <MudTextField 
                    @bind-Value="_senha" 
                    Label="Senha" 
                    Required="true"
                    RequiredError="Senha obrigatória"
                    InputType="@(_mostrarSenha ? InputType.Text : InputType.Password)"
                    Adornment="Adornment.End"
                    AdornmentIcon="@(_mostrarSenha ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                    OnAdornmentClick="() => _mostrarSenha = !_mostrarSenha"
                    HelperText="Mínimo 6 caracteres"
                    Class="mb-4" />
            }
            else
            {
                <div class="d-flex align-center justify-space-between mb-4">
                    <MudAlert Severity="Severity.Info" Class="flex-grow-1 mr-2">
                        Senha protegida (hash Bcrypt).
                    </MudAlert>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="GerarNovaSenha">Redefinir Senha</MudButton>
                </div>
                
                @if (!string.IsNullOrEmpty(_novaSenhaGerada))
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4">
                        A nova senha temporária é: <strong>@_novaSenhaGerada</strong><br/>
                        Copie e envie ao usuário. Ela não será mostrada novamente.
                    </MudAlert>
                }
            }

            <MudSelect 
                @bind-Value="_usuario.NivelAcesso" 
                Label="Nível de Acesso" 
                Required="true"
                RequiredError="Nível obrigatório"
                Class="mb-4">
                <MudSelectItem Value="10">Administrador</MudSelectItem>
                <MudSelectItem Value="5">Operador</MudSelectItem>
                <MudSelectItem Value="1">Visualizador</MudSelectItem>
            </MudSelect>

            <MudCheckBox 
                @bind-Value="_usuario.Ativo" 
                Label="Usuário Ativo"
                Color="Color.Primary"
                Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Salvar" Disabled="@(!_isValid)">
            @(_isNovo ? "Criar" : "Atualizar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private ApplicationDbContext DbContext = default!;

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int? UsuarioId { get; set; }

    private Usuario _usuario = new();
    private string _senha = "";
    private string _novaSenhaGerada = "";
    private bool _mostrarSenha = false;

    // FEAT-11: Redefinir senha (Admin)
    private async Task GerarNovaSenha()
    {
        // Gera uma senha aleatória de 8 caracteres alfanuméricos
        const string chars = "ABCDEFGHJKLMNOPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz0123456789!@#";
        var random = new Random();
        _novaSenhaGerada = new string(Enumerable.Repeat(chars, 8).Select(s => s[random.Next(s.Length)]).ToArray());
        
        var u = await DbContext.Usuarios.FindAsync(_usuario.Id);
        if (u != null)
        {
            u.SenhaHash = BCrypt.Net.BCrypt.HashPassword(_novaSenhaGerada);
            DbContext.Usuarios.Update(u);
            await DbContext.SaveChangesAsync();
            Snackbar.Add("Senha redefinida com sucesso!", Severity.Success);
        }
    }
    private bool _isValid = false;
    private bool _isNovo = true;
    private MudForm _form = null!;

    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();
        if (UsuarioId.HasValue)
        {
            _isNovo = false;
            _usuario = await DbContext.Usuarios.FindAsync(UsuarioId.Value) ?? new();
        }
        else
        {
            _usuario = new();
        }
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_isValid)
            return;

        try
        {
            if (_isNovo)
            {
                if (string.IsNullOrWhiteSpace(_senha) || _senha.Length < 6)
                {
                    Snackbar.Add("Senha deve ter no mínimo 6 caracteres", Severity.Error);
                    return;
                }

                var (sucesso, erro) = await AuthService.RegistrarUsuarioAsync(_usuario, _senha);
                if (!sucesso)
                {
                    Snackbar.Add(erro, Severity.Error);
                    return;
                }
            }
            else
            {
                DbContext.Usuarios.Update(_usuario);
                await DbContext.SaveChangesAsync();
            }

            Snackbar.Add("Usuário salvo com sucesso!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}

