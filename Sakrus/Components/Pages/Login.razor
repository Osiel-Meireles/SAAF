@page "/login"
@attribute [AllowAnonymous]
@layout LoginLayout
@inject NavigationManager Navigation

<PageTitle>Login — SAAF</PageTitle>

<div class="login-form-wrapper">
    <div class="login-form-header">
        <h4 class="login-form-title">Bem-vindo(a)</h4>
        <p class="login-form-subtitle">Por favor, acesse a sua conta</p>
    </div>

    <form method="post" action="/api/auth/login" class="login-fields">
        <AntiforgeryToken />
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />

        <div class="login-field-group">
            <label class="login-label" for="email">Usuário</label>
            <div class="login-input-wrapper">
                <svg class="login-input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
                <input type="text" id="email" name="email" required
                       placeholder="seu@email.com"
                       class="login-input" />
            </div>
        </div>

        <div class="login-field-group">
            <label class="login-label" for="senha">Senha</label>
            <div class="login-input-wrapper">
                <svg class="login-input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                </svg>
                <input type="password" id="senha" name="senha" required
                       placeholder="••••••••"
                       class="login-input" />
            </div>
        </div>

        <div class="login-options">
            <label class="login-checkbox-label">
                <input type="checkbox" name="lembrarMe" value="true" class="login-checkbox" />
                <span>Lembrar por 7 dias</span>
            </label>
        </div>

        @if (_erroLogin)
        {
            <div class="login-alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                <span>E-mail ou senha incorretos. Verifique suas credenciais.</span>
            </div>
        }

        <button type="submit" class="login-btn">
            Acessar o Sistema
        </button>
    </form>

    <div class="login-footer">
        <p class="login-footer-text">
            © @DateTime.Now.Year Prefeitura Municipal de Luís Eduardo Magalhães
        </p>
    </div>
</div>

<style>
    .login-form-wrapper {
        width: 100%;
        padding: 40px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
    }

    .login-form-header {
        margin-bottom: 2rem;
    }

    .login-form-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #2C3531;
        margin: 0 0 0.5rem 0;
        font-size: 2rem;
    }

    .login-form-subtitle {
        color: #707070;
        font-size: 1rem;
        margin: 0;
    }

    .login-fields {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .login-field-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .login-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #3A3A3A;
    }

    .login-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .login-input-icon {
        position: absolute;
        left: 14px;
        width: 20px;
        height: 20px;
        color: #8FA88C;
        pointer-events: none;
    }

    .login-input {
        width: 100%;
        padding: 14px 14px 14px 44px;
        border: 1px solid rgba(180, 172, 161, 0.4);
        border-radius: 12px;
        font-size: 1rem;
        font-family: 'Inter', sans-serif;
        color: #3A3A3A;
        background: #ffffff;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        box-sizing: border-box;
    }

    .login-input::placeholder {
        color: #B4ACA1;
    }

    .login-input:focus {
        border-color: #8FA88C;
        border-width: 2px;
        box-shadow: 0 0 0 3px rgba(143, 168, 140, 0.15);
    }

    .login-options {
        display: flex;
        align-items: center;
        margin-top: 4px;
        margin-bottom: 12px;
    }

    .login-checkbox-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.875rem;
        color: #3A3A3A;
        cursor: pointer;
    }

    .login-checkbox {
        accent-color: #8FA88C;
        width: 16px;
        height: 16px;
    }

    .login-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 12px;
        background-color: #fff0f0;
        color: #d32f2f;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .login-alert svg {
        flex-shrink: 0;
    }

    .login-btn {
        margin-top: 8px;
        border-radius: 12px;
        height: 54px;
        font-weight: 600;
        font-size: 1.05rem;
        font-family: 'Inter', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background-color: #8FA88C;
        color: white;
        border: none;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(143, 168, 140, 0.3);
        transition: all 0.3s ease;
        width: 100%;
    }

    .login-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(143, 168, 140, 0.4);
        background-color: #7e987c;
    }

    .login-btn:active {
        transform: translateY(0);
    }

    .login-footer {
        text-align: center;
        margin-top: 2rem;
    }

    .login-footer-text {
        color: #909090;
        font-size: 0.8rem;
        margin: 0;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private bool _erroLogin => !string.IsNullOrEmpty(Error);
}
