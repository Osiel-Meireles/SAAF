@using MudBlazor
@using Sakrus.Core.Entities
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Agendar Exumação - Gaveta @GavetaNumero</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Defina a data programada para a retirada dos restos mortais.
        </MudAlert>
        <MudDatePicker Label="Data da Exumação" @bind-Date="dataAgendada" Editable="true" />
        <MudTextField @bind-Value="observacoes" Label="Observações / Motivo" Lines="3" Class="mt-4" Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Voltar</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="Confirmar">Confirmar Agendamento</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int GavetaId { get; set; }
    [Parameter] public string GavetaNumero { get; set; } = "";

    private DateTime? dataAgendada = DateTime.Today.AddDays(7);
    private string observacoes = "";

    private async Task Confirmar()
    {
        var gaveta = await DbContext.GavetasPublicas.FindAsync(GavetaId);
        
        if (gaveta == null) return;

        // Atualiza a previsão na gaveta
        gaveta.DataPrevisaoExumacao = dataAgendada;
        
        // Opcional: Criar um registro na sua tabela de ExumacoesRegistros (se existir)
        // DbContext.Exumacoes.Add(new Exumacao { GavetaId = GavetaId, DataProgramada = dataAgendada, Notas = observacoes });

        await DbContext.SaveChangesAsync();
        
        Snackbar.Add($"Exumação da gaveta {GavetaNumero} agendada para {dataAgendada:dd/MM/yyyy}", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancelar() => MudDialog.Cancel();
}