@page "/obitos"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using Sakrus.Core.Entities
@using Sakrus.Infrastructure.Data
@using Sakrus.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject IDialogService DialogService
@inject RelatorioService RelatorioService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IAuthService AuthService

<PageTitle>Gerenciar Atendimentos - Sakrus</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">Gerenciar Atendimentos (Óbitos)</MudText>
    <MudButton Href="/novo-atendimento" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Novo Registro</MudButton>
</div>

<MudTable Items="@listaAtendimentos" Hover="true" Striped="true" Elevation="2" T="Atendimento" Loading="@isLoading" Filter="new Func<Atendimento,bool>(FilterFunc)">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Buscar por responsável, falecido ou OS..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Responsável</MudTh>
        <MudTh>Falecido</MudTh>
        <MudTh>Causa da Morte</MudTh>
        <MudTh>Nº OS / Auxílio</MudTh>
        <MudTh>Ações</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Responsável">@context.Responsavel.Nome</MudTd>
        <MudTd DataLabel="Falecido">@context.Falecido.Nome</MudTd>
        <MudTd DataLabel="Causa da Morte">@context.Falecido.CausaMorte.ToString()</MudTd>
        <MudTd DataLabel="Nº OS / Auxílio">
            @if (string.IsNullOrEmpty(context.NumeroOsAuxilio))
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Pendente</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">@context.NumeroOsAuxilio</MudChip>
            }
        </MudTd>
        <MudTd DataLabel="Ações">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => EditarAtendimento(context))" Title="Editar" />
            
            @* Botão que abre o nosso novo Modal *@
            <MudIconButton Icon="@Icons.Material.Filled.Receipt" Color="Color.Info" Size="Size.Small" OnClick="@(() => AbrirModalFaturamento(context.Id))" Title="Faturamento/OS" />
            
            <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Primary" Size="Size.Small" OnClick="@(() => BaixarGuiaSepultamento(context))" Title="Guia de Sepultamento" />
            
            @if (IsSepultado(context))
            {
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Warning" Size="Size.Small" OnClick="@(() => AbrirRealizarExumacao(context))" Title="Realizar Exumação" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Color="Color.Success" Size="Size.Small" OnClick="@(() => AbrirRealizarSepultamento(context))" Title="Realizar Sepultamento" />
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" RowsPerPageString="Linhas por página:" />
    </PagerContent>
</MudTable>

@code {
    private ApplicationDbContext DbContext = default!;
    private List<Atendimento> listaAtendimentos = new();
    private Dictionary<int, GavetaPublica> falecidosGavetaMap = new();
    private bool isLoading = true;
    private string searchString = "";

    private bool FilterFunc(Atendimento atendimento)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (atendimento.Responsavel?.Nome?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (atendimento.Falecido?.Nome?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (atendimento.NumeroOsAuxilio?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        return false;
    }

    private bool IsSepultado(Atendimento a)
    {
        if (a?.Falecido == null) return false;
        return a.Falecido.JazigoId != null || falecidosGavetaMap.ContainsKey(a.FalecidoId);
    }

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();
        await CarregarDadosAsync();
    }

    private async Task CarregarDadosAsync()
    {
        isLoading = true;
        listaAtendimentos = await DbContext.Atendimentos
            .Include(a => a.Responsavel)
            .Include(a => a.Falecido)
            .Include(a => a.Falecido.Jazigo)
            .OrderByDescending(a => a.Id)
            .ToListAsync();

        var falecidosIds = listaAtendimentos.Select(a => a.FalecidoId).ToList();
        var gavetasOcupadas = await DbContext.GavetasPublicas
            .Where(g => g.FalecidoId != null && falecidosIds.Contains(g.FalecidoId.Value) && g.Ocupada)
            .ToListAsync();

        falecidosGavetaMap = new Dictionary<int, GavetaPublica>();
        foreach (var g in gavetasOcupadas)
        {
            if (g.FalecidoId.HasValue)
            {
                falecidosGavetaMap[g.FalecidoId.Value] = g;
            }
        }
            
        isLoading = false;
        StateHasChanged();
    }

    private async Task AbrirModalFaturamento(int id)
    {
        // Prepara os parâmetros para enviar ao Modal (Qual ID de atendimento abrir)
        var parameters = new DialogParameters { ["AtendimentoId"] = id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        // Abre o modal
        var dialog = await DialogService.ShowAsync<FaturamentoDialog>("Faturamento do Atendimento", parameters, options);
        var result = await dialog.Result;

        // Se o usuário finalizou a OS (não cancelou), recarrega a tabela para atualizar a coluna "Nº OS / Auxílio"
        if (result != null && !result.Canceled)
        {
            await CarregarDadosAsync();
        }
    }

    private async Task BaixarGuiaSepultamento(Atendimento atendimento)
    {
        try
        {
            var pdfBytes = RelatorioService.GerarPdfGuiaSepultamento(atendimento.Falecido, atendimento);
            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Guia_Sepultamento_{atendimento.Falecido.Nome.Replace(" ", "_")}.pdf";

            // Chama função JS no lado do cliente para baixar o arquivo
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
            Snackbar.Add("Guia de Sepultamento gerada com sucesso!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao gerar PDF: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditarAtendimento(Atendimento atendimento)
    {
        // 2FA — Confirmação de senha antes de editar
        var param2FA = new DialogParameters
        {
            ["TituloOperacao"] = "Editar Atendimento",
            ["MensagemConfirmacao"] = $"Você está prestes a editar o atendimento #{atendimento.Id}. Confirme sua identidade."
        };
        var opt2FA = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dlg2FA = await DialogService.ShowAsync<ConfirmacaoSenhaDialog>("Confirmação de Segurança", param2FA, opt2FA);
        var res2FA = await dlg2FA.Result;
        if (res2FA == null || res2FA.Canceled) return;

        var parameters = new DialogParameters 
        { 
            ["AtendimentoId"] = atendimento.Id,
            ["Responsavel"] = atendimento.Responsavel,
            ["Falecido"] = atendimento.Falecido
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<EditarAtendimentoDialog>("Editar Atendimento", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await CarregarDadosAsync();
            Snackbar.Add("Atendimento atualizado com sucesso!", Severity.Success);
        }
    }

    private async Task AbrirRealizarSepultamento(Atendimento atendimento)
    {
        var parameters = new DialogParameters 
        { 
            ["AtendimentoId"] = atendimento.Id,
            ["FalecidoId"] = atendimento.FalecidoId,
            ["FalecidoNome"] = atendimento.Falecido?.Nome ?? ""
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<RealizarSepultamentoDialog>("Realizar Sepultamento", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await CarregarDadosAsync();
        }
    }

    private async Task AbrirRealizarExumacao(Atendimento atendimento)
    {
        var parameters = new DialogParameters 
        { 
            ["AtendimentoId"] = atendimento.Id,
            ["FalecidoId"] = atendimento.FalecidoId,
            ["FalecidoNome"] = atendimento.Falecido?.Nome ?? ""
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<RealizarExumacaoObitoDialog>("Realizar Exumação", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await CarregarDadosAsync();
        }
    }
}
