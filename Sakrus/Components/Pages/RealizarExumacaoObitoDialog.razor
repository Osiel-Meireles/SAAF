@using MudBlazor
@using Sakrus.Core.Entities
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Realizar Exumação - @FalecidoNome</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <MudProgressLinear Color="Color.Warning" Indeterminate="true" Class="my-4" />
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                <strong>Localização Atual:</strong> @localAtual
            </MudAlert>

            <MudForm @ref="form" @bind-IsValid="sucesso">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Data da Execução" @bind-Date="dataExecucao" Required="true" RequiredError="Data é obrigatória" Editable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Data Autorização" @bind-Date="dataAutorizacao" Required="true" Editable="true" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="setorAutorizador" Label="Setor Autorizador" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="ExecutorExumacao" Label="Executor" @bind-Value="executor" Required="true">
                            @foreach (ExecutorExumacao exec in Enum.GetValues(typeof(ExecutorExumacao)))
                            {
                                <MudSelectItem Value="@exec">@exec.ToString()</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12">
                        <MudSelect T="int?" Label="Destino da Ossada (Ossuário Geral)" @bind-Value="selectedOssuarioId" Clearable="true">
                            <MudSelectItem T="int?" Value="null">Outro (Ex: Jazigo/Cremação)</MudSelectItem>
                            @foreach (var o in ossuariosGerais)
                            {
                                <MudSelectItem T="int?" Value="@o.Id">@o.Identificador (Capacidade: @o.Capacidade)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12">
                        <MudSelect T="int?" Label="Selecione Novo Jazigo de Destino (Opcional)" @bind-Value="destinoJazigoId" Clearable="true">
                            <MudSelectItem T="int?" Value="null">Nenhum</MudSelectItem>
                            @foreach (var j in jazigosList)
                            {
                                <MudSelectItem T="int?" Value="@j.Id">Jazigo @j.CodigoIdentificador @(j.Ocupado ? "(Ocupado)" : "(Livre)")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="observacoes" Label="Observações Adicionais" Lines="3" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="Confirmar" Disabled="@(!sucesso || isLoading)">Confirmar Exumação</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private ApplicationDbContext DbContext = default!;

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int AtendimentoId { get; set; }
    [Parameter] public int FalecidoId { get; set; }
    [Parameter] public string FalecidoNome { get; set; } = "";

    private MudForm form = null!;
    private bool sucesso;
    private bool isLoading = true;

    private string localAtual = "Carregando...";
    private Jazigo? currentJazigo;
    private GavetaPublica? currentGaveta;

    private DateTime? dataExecucao = DateTime.Today;
    private DateTime? dataAutorizacao = DateTime.Today;
    private string setorAutorizador = "CAAF";
    private ExecutorExumacao executor = ExecutorExumacao.CemiterioMunicipal;
    private int? selectedOssuarioId;
    private int? destinoJazigoId;
    private string observacoes = "";

    private List<Ossuario> ossuariosGerais = new();
    private List<Jazigo> jazigosList = new();

    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();
        await CarregarDadosAsync();
    }

    private async Task CarregarDadosAsync()
    {
        isLoading = true;

        var falecido = await DbContext.Falecidos
            .FirstOrDefaultAsync(f => f.Id == FalecidoId);

        if (falecido != null)
        {
            if (falecido.JazigoId.HasValue)
            {
                currentJazigo = await DbContext.Jazigos.FindAsync(falecido.JazigoId.Value);
            }
            currentGaveta = await DbContext.GavetasPublicas.FirstOrDefaultAsync(g => g.FalecidoId == FalecidoId && g.Ocupada);
        }

        if (currentJazigo != null)
        {
            localAtual = $"Jazigo {currentJazigo.CodigoIdentificador}";
        }
        else if (currentGaveta != null)
        {
            localAtual = $"Gaveta Pública {currentGaveta.NumeroGaveta}";
        }
        else
        {
            localAtual = "Não sepultado / Local desconhecido";
        }

        ossuariosGerais = await DbContext.Ossuarios.Where(o => o.Tipo == TipoOssuario.Geral).ToListAsync();
        jazigosList = await DbContext.Jazigos.OrderBy(j => j.CodigoIdentificador).ToListAsync();

        isLoading = false;
        StateHasChanged();
    }

    private async Task Confirmar()
    {
        await form.Validate();
        if (!form.IsValid) return;

        isLoading = true;
        StateHasChanged();

        using var transaction = await DbContext.Database.BeginTransactionAsync();
        try
        {
            var falecido = await DbContext.Falecidos
                .FirstOrDefaultAsync(f => f.Id == FalecidoId);

            if (falecido == null)
            {
                Snackbar.Add("Falecido não encontrado.", Severity.Error);
                isLoading = false;
                StateHasChanged();
                return;
            }

            var dateExec = dataExecucao.HasValue ? DateTime.SpecifyKind(dataExecucao.Value, DateTimeKind.Utc) : DateTime.UtcNow;
            var dateAut = dataAutorizacao.HasValue ? DateTime.SpecifyKind(dataAutorizacao.Value, DateTimeKind.Utc) : DateTime.UtcNow;

            var registro = new ExumacaoRegistro
            {
                FalecidoId = FalecidoId,
                DataExecucao = dateExec,
                DataAutorizacao = dateAut,
                SetorAutorizador = setorAutorizador,
                Executor = executor,
                Observacoes = observacoes,
                OssuarioDestinoId = selectedOssuarioId,
                JazigoId = currentJazigo?.Id,
                GavetaPublicaId = currentGaveta?.Id
            };

            // 1. Liberar o local anterior
            if (currentJazigo != null)
            {
                // Desvincula o falecido do jazigo antigo
                falecido.JazigoId = null;

                // Apenas libera o Jazigo antigo se não houver mais nenhum falecido ocupando ele
                var outroFalecido = await DbContext.Falecidos
                    .AnyAsync(f => f.JazigoId == currentJazigo.Id && f.Id != FalecidoId);

                if (!outroFalecido)
                {
                    currentJazigo.Ocupado = false;
                    DbContext.Jazigos.Update(currentJazigo);
                }
            }
            else if (currentGaveta != null)
            {
                currentGaveta.Ocupada = false;
                currentGaveta.FalecidoId = null;
                currentGaveta.DataOcupacao = null;
                currentGaveta.DataPrevisaoExumacao = null;
                DbContext.GavetasPublicas.Update(currentGaveta);
            }

            // 2. Definir o novo destino
            if (selectedOssuarioId.HasValue)
            {
                falecido.OssuarioId = selectedOssuarioId;
            }
            else if (destinoJazigoId.HasValue)
            {
                falecido.JazigoId = destinoJazigoId;
                
                var destJazigo = await DbContext.Jazigos.FindAsync(destinoJazigoId.Value);
                if (destJazigo != null)
                {
                    destJazigo.Ocupado = true;
                    DbContext.Jazigos.Update(destJazigo);
                }
            }

            DbContext.ExumacoesRegistros.Add(registro);
            DbContext.Falecidos.Update(falecido);

            await DbContext.SaveChangesAsync();
            await transaction.CommitAsync();

            Snackbar.Add($"Exumação de {FalecidoNome} concluída com sucesso!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            await transaction.RollbackAsync();
            Snackbar.Add($"Erro ao exumar: {ex.Message}", Severity.Error);
            isLoading = false;
            StateHasChanged();
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}
