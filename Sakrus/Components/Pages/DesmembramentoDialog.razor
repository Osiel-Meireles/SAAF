@using MudBlazor
@using Sakrus.Core.Entities
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Desmembrar Jazigo: @CodigoIdentificadorPai</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-4">
            Atenção: O lote principal será marcado como ocupado/indisponível para novos sepultamentos individuais.
        </MudAlert>
        <MudNumericField @bind-Value="quantidade" Label="Número de Divisões" 
                         Min="2" Max="6" Variant="Variant.Outlined" HelperText="Mínimo 2, Máximo 6 partes" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Voltar</MudButton>
        <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="ExecutarDivisao">Confirmar Divisão</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int JazigoId { get; set; }
    [Parameter] public string CodigoIdentificadorPai { get; set; } = "";

    private int quantidade = 2;

    private async Task ExecutarDivisao()
    {
        var pai = await DbContext.Jazigos.FindAsync(JazigoId);
        
        if (pai == null || pai.Ocupado)
        {
            Snackbar.Add("Este lote já está ocupado ou não foi encontrado.", Severity.Error);
            return;
        }

        // Criar os novos sub-lotes
        char letra = 'A';
        for (int i = 0; i < quantidade; i++)
        {
            var subLote = new Jazigo
            {
                CodigoIdentificador = $"{pai.CodigoIdentificador}-{letra}",
                ModeloJazigoId = pai.ModeloJazigoId,
                IsInfantil = pai.IsInfantil,
                JazigoPaiId = pai.Id,
                Ocupado = false,
                CoordenadasMapa = pai.CoordenadasMapa // Herda a posição aproximada no mapa
            };
            
            DbContext.Jazigos.Add(subLote);
            letra++;
        }

        // Marcamos o pai como ocupado para que ele saia da lista de "Disponíveis"
        pai.Ocupado = true; 
        
        await DbContext.SaveChangesAsync();
        
        Snackbar.Add($"Lote {pai.CodigoIdentificador} desmembrado em {quantidade} partes.", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancelar() => MudDialog.Cancel();
}