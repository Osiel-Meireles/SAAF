@using MudBlazor
@using Sakrus.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudTextField @bind-Value="_senhaAtual" Label="Senha Atual" Required="true" RequiredError="Informe sua senha atual" InputType="@(_mostrarSenha ? InputType.Text : InputType.Password)" Class="mb-4" />
            
            <MudTextField @bind-Value="_novaSenha" Label="Nova Senha" Required="true" RequiredError="Informe a nova senha" InputType="@(_mostrarSenha ? InputType.Text : InputType.Password)" HelperText="Mínimo 8 caracteres, ao menos 1 maiúscula e 1 número" Class="mb-4" />
            
            <MudTextField @bind-Value="_confirmarNovaSenha" Label="Confirmar Nova Senha" Required="true" RequiredError="Confirme a nova senha" InputType="@(_mostrarSenha ? InputType.Text : InputType.Password)" 
                          Validation="@(new Func<string, string>(ValidarConfirmacaoSenha))" Class="mb-4" />
            
            <MudCheckBox @bind-Value="_mostrarSenha" Label="Mostrar senhas" Color="Color.Primary" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SalvarSenha" Disabled="@(!_isValid || _salvando)">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = null!;
    
    private string _senhaAtual = "";
    private string _novaSenha = "";
    private string _confirmarNovaSenha = "";
    private bool _mostrarSenha = false;
    private bool _isValid = false;
    private bool _salvando = false;
    
    private int _usuarioLogadoId = 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int id))
        {
            _usuarioLogadoId = id;
        }
    }

    private string ValidarConfirmacaoSenha(string arg)
    {
        if (_novaSenha != arg)
            return "As senhas não coincidem.";
        return null!;
    }

    private async Task SalvarSenha()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _salvando = true;
        
        try
        {
            // BUG-03: Usar AuthService em vez de acesso direto ao DbContext
            var (sucesso, erro) = await AuthService.AlterarSenhaAsync(_usuarioLogadoId, _senhaAtual, _novaSenha);
            
            if (!sucesso)
            {
                Snackbar.Add(erro, Severity.Error);
                _salvando = false;
                return;
            }

            Snackbar.Add("Senha alterada com sucesso!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao alterar senha: {ex.Message}", Severity.Error);
        }
        finally
        {
            _salvando = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
