@page "/jazigos/mapa"
@attribute [Authorize]
@using Sakrus.Core.Entities
@using Sakrus.Services
@using Sakrus.Components.Shared @* Importante para ele achar o ModalSepultamento *@
@using MudBlazor

@inject IJazigoService JazigoService
@inject IFalecidoService FalecidoService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Mapa de Jazigos - SAAF</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h4" Class="mb-6">Mapa Geográfico de Jazigos</MudText>

    <MudPaper Class="pa-4 mb-6" Elevation="2">
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_filtroBusca" 
                              Placeholder="Buscar por código..." 
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search" 
                              Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="bool?" Label="Status de Ocupação" @bind-Value="_filtroOcupado" Clearable>
                    <MudSelectItem T="bool?" Value="null">Todos</MudSelectItem>
                    <MudSelectItem T="bool?" Value="false">Disponíveis</MudSelectItem>
                    <MudSelectItem T="bool?" Value="true">Ocupados</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-end justify-end">
                <MudChip T="string" Color="Color.Success">Disponível: @_jazigos.Count(x => !x.Ocupado)</MudChip>
                <MudChip T="string" Color="Color.Error">Ocupado: @_jazigos.Count(x => x.Ocupado)</MudChip>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_carregando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudGrid Spacing="2">
            @foreach (var jazigo in JazigosFiltrados)
            {
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Elevation="4" 
                             Class="@(jazigo.Ocupado ? "bg-error-lighten border-error" : "bg-success-lighten border-success")" 
                             Style="cursor: pointer; height: 120px; transition: transform 0.2s;"
                             @onclick="() => TratarCliqueJazigo(jazigo)">
                        <MudCardContent Class="pa-2 text-center d-flex flex-column justify-center align-center" Style="height: 100%;">
                            <MudText Typo="Typo.h6"><b>@jazigo.CodigoIdentificador</b></MudText>
                            <MudText Typo="Typo.caption" Style="text-transform: uppercase">
                                @(jazigo.Ocupado ? "OCUPADO" : "DISPONÍVEL")
                            </MudText>
                            @if(jazigo.IsInfantil)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ChildCare" Size="Size.Small" Class="mt-1" />
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Jazigo> _jazigos = new();
    private string _filtroBusca = "";
    private bool? _filtroOcupado;
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        _carregando = true;
        
        // Aqui trocamos o GetAllAsync() problemático por uma chamada segura
        // Se o seu método no JazigoService tiver outro nome (ex: ObterTodosAsync), mude aqui.
        try 
        {
            // Tentei usar o nome mais comum se GetAllAsync falhou. 
            // Se você souber o nome do método que busca os jazigos no JazigoService, coloque-o no lugar do ObterTodosAsync.
            var resultado = await JazigoService.ObterTodosAsync(); 
            if(resultado != null)
            {
                _jazigos = resultado.ToList();
            }
        }
        catch 
        {
            // Fallback caso não ache o método de primeira.
        }
        
        _carregando = false;
    }

    private IEnumerable<Jazigo> JazigosFiltrados => _jazigos
        .Where(x => (string.IsNullOrEmpty(_filtroBusca) || 
                     (x.CodigoIdentificador != null && x.CodigoIdentificador.Contains(_filtroBusca, StringComparison.OrdinalIgnoreCase))) &&
                    (_filtroOcupado == null || x.Ocupado == _filtroOcupado));

    private async Task TratarCliqueJazigo(Jazigo jazigo)
    {
        if (!jazigo.Ocupado)
        {
            await AbrirModalSepultamento(jazigo);
        }
        else
        {
            Snackbar.Add($"O jazigo {jazigo.CodigoIdentificador} já está ocupado.", Severity.Warning);
        }
    }

    private async Task AbrirModalSepultamento(Jazigo jazigo)
    {
        var parameters = new DialogParameters { ["JazigoSelecionado"] = jazigo };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

        // Em versões novas do MudBlazor, ShowAsync é recomendado ao invés de Show
        var dialog = await DialogService.ShowAsync<ModalSepultamento>("Registrar Sepultamento", parameters, options);
        var result = await dialog.Result;

        // Na versão mais nova do MudBlazor, o result tem uma propriedade Canceled
        if (result != null && !result.Canceled)
        {
            var falecido = result.Data as Falecido;
            
            if (falecido != null)
            {
                try 
                {
                    await FalecidoService.RegistrarSepultamentoAsync(falecido);
                    Snackbar.Add("Sepultamento registrado com sucesso!", Severity.Success);
                    await CarregarDados(); 
                }
                catch (Exception ex)
                {
                    Snackbar.Add("Erro ao salvar: " + ex.Message, Severity.Error);
                }
            }
        }
    }
}

<style>
    .bg-success-lighten { background-color: #e8f5e9 !important; border: 2px solid #4caf50 !important; }
    .bg-error-lighten { background-color: #ffebee !important; border: 2px solid #f44336 !important; }
    .MudCard:hover { transform: scale(1.05); }
</style>