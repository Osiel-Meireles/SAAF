@page "/novo-atendimento"
@attribute [Authorize]
@using Sakrus.Core.Entities
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject Sakrus.Services.IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Novo Atendimento - Sakrus</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Registro de Novo Atendimento</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudForm @ref="form" @bind-IsValid="@sucesso">
        <MudGrid>
            @* --- 1. DADOS DO RESPONSÁVEL --- *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Color="Color.Primary">Dados do Responsável</MudText>
                <MudDivider Class="mb-3" />
            </MudItem>
            
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.Nome" Label="Nome Completo" Required="true" RequiredError="O nome é obrigatório" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.CPF" Label="CPF (somente números)" Required="true" RequiredError="CPF obrigatório" HelperText="11 dígitos, sem pontuação" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.RG" Label="RG" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.OrgaoEmissor" Label="Órgão Emissor" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.Profissao" Label="Profissão" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.Telefone" Label="Telefone" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="9">
                <MudTextField @bind-Value="novoAtendimento.Responsavel.Endereco" Label="Endereço Completo" Required="true" />
            </MudItem>

            @* --- 2. DADOS DO FALECIDO --- *@
            <MudItem xs="12" Class="mt-4">
                <MudText Typo="Typo.h6" Color="Color.Primary">Dados do Falecido</MudText>
                <MudDivider Class="mb-3" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="novoAtendimento.Falecido.Nome" Label="Nome Completo do Falecido" Required="true" RequiredError="Nome é obrigatório" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.Falecido.Cpf" Label="CPF do Falecido (somente números)" Required="true" RequiredError="CPF é obrigatório" HelperText="11 dígitos, sem pontuação" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="Data de Falecimento" @bind-Date="dataFalecimento" Required="true" RequiredError="Data obrigatória" />
            </MudItem>
            
            @if (novoAtendimento.Falecido.TipoRestosMortais != TipoRestosMortais.PecaAnatomica)
            {
                <MudItem xs="12" sm="3">
                    <MudSelect T="CausaMorte" Label="Causa da Morte" @bind-Value="novoAtendimento.Falecido.CausaMorte" Required="true">
                        @foreach (CausaMorte causa in Enum.GetValues(typeof(CausaMorte)))
                        {
                            <MudSelectItem Value="@causa">@causa.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
            else
            {
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="novoAtendimento.PecaAnatomicaHospital" Label="Hospital de Origem / CRM Médico" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="novoAtendimento.PecaAnatomicaIdentificacao" Label="Identificação da Peça" Required="true" />
                </MudItem>
            }
            
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudSelect T="TipoRestosMortais" Label="Tipo Restos Mortais" @bind-Value="novoAtendimento.Falecido.TipoRestosMortais" Required="true">
                    @foreach (TipoRestosMortais tipo in Enum.GetValues(typeof(TipoRestosMortais)))
                    {
                        <MudSelectItem Value="@tipo">@tipo.ToString()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="novoAtendimento.NumeroDeclaracaoObito" Label="NÂº Declaração de Óbito" Required="true" />
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="novoAtendimento.LocalFalecimento" Label="Local do Falecimento" Required="true" />
            </MudItem>

            @* --- 3. INFORMAÇÕES DO ATENDIMENTO --- *@
            <MudItem xs="12" Class="mt-4">
                <MudText Typo="Typo.h6" Color="Color.Primary">Classificação do Atendimento</MudText>
                <MudDivider Class="mb-3" />
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudSelect T="PerfilAtendimento" Label="Perfil" @bind-Value="novoAtendimento.Perfil" Required="true">
                    @foreach (PerfilAtendimento perfil in Enum.GetValues(typeof(PerfilAtendimento)))
                    {
                        <MudSelectItem Value="@perfil">@perfil.ToString()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudSelect T="OrigemAtendimento" Label="Origem" @bind-Value="novoAtendimento.Origem" Required="true">
                    @foreach (OrigemAtendimento origem in Enum.GetValues(typeof(OrigemAtendimento)))
                    {
                        <MudSelectItem Value="@origem">@origem.ToString()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudSelect T="TipoProcedimento" Label="Procedimento" @bind-Value="novoAtendimento.Procedimento" Required="true">
                    @foreach (TipoProcedimento procedimento in Enum.GetValues(typeof(TipoProcedimento)))
                    {
                        <MudSelectItem Value="@procedimento">@procedimento.ToString()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudSelect T="int?" Label="Funerária Credenciada (Opcional)" @bind-Value="novoAtendimento.FunerariaId">
                    <MudSelectItem T="int?" Value="null">Nenhuma / Próprio Município</MudSelectItem>
                    @foreach (var f in funerarias)
                    {
                        <MudSelectItem T="int?" Value="@f.Id">@f.Nome</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @* --- BOTÃƒO DE AÇÃƒO --- *@
            <MudItem xs="12" Class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Text" Color="Color.Default" Class="mr-2" OnClick="@Cancelar">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!sucesso)" OnClick="@SalvarAtendimento">Salvar Atendimento</MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

@code {
    private ApplicationDbContext DbContext = default!;

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    private MudForm form = null!;
    private bool sucesso;
    
    // Instancia o objeto já com as entidades filhas para evitar NullReferenceException no Bind do form
    private Atendimento novoAtendimento = new Atendimento
    {
        Responsavel = new Responsavel(),
        Falecido = new Falecido()
    };
    
    private DateTime? dataFalecimento = DateTime.Today;
    private List<Funeraria> funerarias = new();

    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();
        funerarias = await DbContext.Funerarias.ToListAsync();
    }

    private async Task SalvarAtendimento()
    {
        await form.Validate();
        if (form.IsValid)
        {
            // FEAT-02: Validação matemática do CPF
            if (!Sakrus.Core.Helpers.DocumentValidator.IsCpfValido(novoAtendimento.Responsavel.CPF))
            {
                Snackbar.Add("O CPF do Responsável é inválido.", Severity.Error);
                return;
            }
            if (!string.IsNullOrWhiteSpace(novoAtendimento.Falecido.Cpf) && !Sakrus.Core.Helpers.DocumentValidator.IsCpfValido(novoAtendimento.Falecido.Cpf))
            {
                Snackbar.Add("O CPF do Falecido é inválido.", Severity.Error);
                return;
            }
            await using var transaction = await DbContext.Database.BeginTransactionAsync();
            try
            {
                // Atribuir data de falecimento do DatePicker
                if (dataFalecimento.HasValue)
                {
                    novoAtendimento.Falecido.DataFalecimento = DateTime.SpecifyKind(dataFalecimento.Value, DateTimeKind.Utc);
                }
                else
                {
                    novoAtendimento.Falecido.DataFalecimento = DateTime.UtcNow;
                }

                // BUG-07: Verificar se Responsável já existe pelo CPF (apenas números)
                var cpfLimpo = new string(novoAtendimento.Responsavel.CPF.Where(char.IsDigit).ToArray());
                var responsavelExistente = await DbContext.Responsaveis
                    .FirstOrDefaultAsync(r => r.CPF.Replace(".", "").Replace("-", "") == cpfLimpo);

                if (responsavelExistente != null)
                {
                    novoAtendimento.Responsavel = responsavelExistente;
                    novoAtendimento.ResponsavelId = responsavelExistente.Id;
                }
                else
                {
                    // Força o CPF sem máscara antes de salvar
                    novoAtendimento.Responsavel.CPF = cpfLimpo;
                    DbContext.Responsaveis.Add(novoAtendimento.Responsavel);
                    await DbContext.SaveChangesAsync();
                    novoAtendimento.ResponsavelId = novoAtendimento.Responsavel.Id;
                }

                // Salvar Falecido primeiro se for novo
                if (novoAtendimento.FalecidoId == 0 || novoAtendimento.Falecido.Id == 0)
                {
                    // Limpar CPF do falecido também
                    if (!string.IsNullOrEmpty(novoAtendimento.Falecido.Cpf))
                    {
                        novoAtendimento.Falecido.Cpf = new string(novoAtendimento.Falecido.Cpf.Where(char.IsDigit).ToArray());
                    }
                    DbContext.Falecidos.Add(novoAtendimento.Falecido);
                    await DbContext.SaveChangesAsync();
                    novoAtendimento.FalecidoId = novoAtendimento.Falecido.Id;
                }

                // Agora salvar o Atendimento com as FK corrigidas
                DbContext.Atendimentos.Add(novoAtendimento);
                await DbContext.SaveChangesAsync();
                
                await transaction.CommitAsync();
                
                // FEAT-01: Auditoria
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                if (user.Identity?.IsAuthenticated == true)
                {
                    int userId = int.Parse(user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
                    string userName = user.Identity.Name ?? "Desconhecido";
                    
                    await AuditService.LogAcaoAsync(
                        userId, userName, "CREATE", "Atendimento", novoAtendimento.Id.ToString(), null, 
                        new { novoAtendimento.NumeroOsAuxilio, FalecidoId = novoAtendimento.FalecidoId, ResponsavelId = novoAtendimento.ResponsavelId }
                    );
                }
                
                Snackbar.Add("Atendimento registrado com sucesso!", Severity.Success);
                Navigation.NavigateTo("/obitos");
            }
            catch (Exception ex)
            {
                await transaction.RollbackAsync();
                Snackbar.Add($"Erro ao salvar: {ex.Message}", Severity.Error);
            }
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/obitos");
    }
}
