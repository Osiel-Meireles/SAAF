@page "/usuarios"
@attribute [Authorize(Roles = "Admin")]
@using Sakrus.Core.Entities
@using Sakrus.Core.Enums
@using Sakrus.Services
@using Sakrus.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@implements IDisposable
@inject IAuthService AuthService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Gestão de Usuários - SAAF</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">Gestão de Usuários</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AbrirDialogNovoUsuario">Novo Usuário</MudButton>
</div>

<MudAlert Severity="Severity.Info" Class="mb-4">
    Apenas administradores podem criar e gerenciar usuários do sistema.
</MudAlert>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudTable Items="@usuarios" Hover="true" Striped="true" Elevation="2" Filter="new Func<Usuario,bool>(FilterFunc)">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Buscar por nome ou e-mail..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Nome</MudTh>
            <MudTh>E-mail</MudTh>
            <MudTh>Nível de Acesso</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nome">@context.Nome</MudTd>
            <MudTd DataLabel="E-mail">@context.Email</MudTd>
            <MudTd DataLabel="Nível">
                <MudChip T="string" Size="Size.Small">
                    @NivelAcessoHelper.ParaLabel(context.NivelAcesso)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.Ativo ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.Ativo ? "Ativo" : "Inativo")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => AbrirDialogEditarUsuario(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DesativarUsuario(context.Id, context.Nome))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    private ApplicationDbContext DbContext = default!;
    private List<Usuario> usuarios = new();
    private bool isLoading = true;
    private string searchString = "";

    public void Dispose()
    {
        DbContext?.Dispose();
    }

    private bool FilterFunc(Usuario usuario)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (usuario.Nome?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (usuario.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();
        await CarregarUsuarios();
    }

    private async Task CarregarUsuarios()
    {
        isLoading = true;
        usuarios = await DbContext.Usuarios.OrderBy(u => u.Nome).ToListAsync();
        isLoading = false;
    }

    private async Task AbrirDialogNovoUsuario()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<UsuarioDialog>("Novo Usuário", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await CarregarUsuarios();
            Snackbar.Add("Usuário criado com sucesso!", Severity.Success);
        }
    }

    private async Task AbrirDialogEditarUsuario(Usuario usuario)
    {
        // 2FA — Confirmação de senha antes de editar
        var param2FA = new DialogParameters
        {
            ["TituloOperacao"] = "Editar Usuário",
            ["MensagemConfirmacao"] = $"Você está prestes a editar o usuário '{usuario.Nome}'. Confirme sua identidade."
        };
        var opt2FA = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dlg2FA = await DialogService.ShowAsync<ConfirmacaoSenhaDialog>("Confirmação de Segurança", param2FA, opt2FA);
        var res2FA = await dlg2FA.Result;
        if (res2FA == null || res2FA.Canceled) return;

        var parameters = new DialogParameters { ["UsuarioId"] = usuario.Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<UsuarioDialog>("Editar Usuário", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await CarregarUsuarios();
            Snackbar.Add("Usuário atualizado com sucesso!", Severity.Success);
        }
    }

    private async Task DesativarUsuario(int usuarioId, string nome)
    {
        // 2FA — Confirmação de senha antes de desativar
        var param2FA = new DialogParameters
        {
            ["TituloOperacao"] = "Desativar Usuário",
            ["MensagemConfirmacao"] = $"Você está prestes a desativar o usuário '{nome}'. Confirme sua identidade."
        };
        var opt2FA = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dlg2FA = await DialogService.ShowAsync<ConfirmacaoSenhaDialog>("Confirmação de Segurança", param2FA, opt2FA);
        var res2FA = await dlg2FA.Result;
        if (res2FA == null || res2FA.Canceled) return;

        bool? resultado = await DialogService.ShowMessageBoxAsync(
            "Desativar Usuário",
            $"Tem certeza que deseja desativar {nome}? Esta ação pode ser revertida.",
            yesText: "Sim, Desativar", cancelText: "Cancelar");

        if (resultado == true)
        {
            try
            {
                var usuario = await DbContext.Usuarios.FindAsync(usuarioId);
                if (usuario != null)
                {
                    usuario.Ativo = false;
                    DbContext.Usuarios.Update(usuario);
                    await DbContext.SaveChangesAsync();
                    await CarregarUsuarios();
                    Snackbar.Add("Usuário desativado com sucesso!", Severity.Success);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erro ao desativar: {ex.Message}", Severity.Error);
            }
        }
    }
}

